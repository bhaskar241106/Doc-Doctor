# Local AI Provider Configurations
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Database and Storage Paths
CHROMADB_DIR=./data/chromadb
METADATA_DB_PATH=./data/metadata.db
CLONE_DIR=./data/repos

# Server Configurations
PORT=8000
HOST=0.0.0.0

# Switchable AI Provider Configurations (local or online)
AI_PROVIDER=local
OFFLINE_MODE=true

# Online AI Provider Configurations (e.g., OpenAI)
# Provide your own API key here if switching AI_PROVIDER to 'online'
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
